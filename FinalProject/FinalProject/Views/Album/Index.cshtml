@model IEnumerable<FinalProject.Models.Album>

@{
    ViewData["Title"] = "Albums List";
}
<h2>Albums List</h2>

<p>
    <a asp-action="Create" class="btn btn-outline-success">Create New</a>
</p>

<form asp-action="Index" method="get" class="mb-3">

    <label class="form-label fw-bold">Filter by Type:</label>

    <select name="type" class="form-select w-25 d-inline-block">
        <option value="">All</option>
        <option value="Vinyl">Vinyl</option>
        <option value="CD">CD</option>
        <option value="Cassette">Cassette</option>
    </select>

    <input type="submit" value="Filter" class="btn btn-primary ms-2" />

</form>
<table class="table table-striped">
    <thead class="table-primary">
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Artist)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Genre)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Type)
            </th> 
            <th></th>
        </tr>
    </thead>
    <tbody>
 @foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.Name)
            </td>
            <td>
                @Html.DisplayFor(model => item.Artist)
            </td>
            <td>
                @Html.DisplayFor(model => item.Genre)
            </td>
            
            <td>
                @Html.DisplayFor(model => item.Type)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
